# Root development environment contract for XAI Books

POSTGRES_DB=xai_books
POSTGRES_USER=xai_books
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
POSTGRES_CONTAINER_PORT=5432

DATABASE_URL=postgresql+psycopg://xai_books:change-me@postgres:5432/xai_books

API_PORT=8000
API_CONTAINER_PORT=8000

WEB_PORT=5173
WEB_CONTAINER_PORT=5173

MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Next.js web authentication app
WEB_DATABASE_URL=postgresql://xai_books:change-me@localhost:5432/xai_books
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Transactional email. Resend is preferred, SendGrid is supported, SMTP is fallback.
EMAIL_FROM="XAI Books <noreply@xaibooks.ae>"
EMAIL_FROM_ADDRESS=noreply@xaibooks.ae
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
