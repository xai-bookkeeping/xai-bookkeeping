{
  "name": "xai-books-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "gen-types": "openapi-ts --input /spec/openapi.json --output src/api",
    "preview": "vite preview --host 0.0.0.0 --port ${WEB_CONTAINER_PORT:-5173}",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "5.100.14",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "6.30.1"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.98.1",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
}
