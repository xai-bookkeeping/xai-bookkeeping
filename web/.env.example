# ─────────────────────────────────────────────
# Database
# WEB_DATABASE_URL is the variable Prisma actually reads (see prisma/schema.prisma).
# DATABASE_URL is kept for tooling/scripts that expect the conventional name.
# Keep both pointing at the same database.
# ─────────────────────────────────────────────
WEB_DATABASE_URL="postgresql://xai_books:change-me@localhost:5432/xai_books"
DATABASE_URL="postgresql://xai_books:change-me@localhost:5432/xai_books"

# ─────────────────────────────────────────────
# Clerk
# ─────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/register"
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="XAI Books"

# ─────────────────────────────────────────────
# Email (SMTP)
# Development: use Mailhog (smtp://localhost:1025)
# Production: use your SMTP provider
# ─────────────────────────────────────────────
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="XAI Books <noreply@xaibooks.ae>"

# ─────────────────────────────────────────────
