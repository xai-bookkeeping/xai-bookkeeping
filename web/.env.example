# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://xai_books:change-me@localhost:5432/xai_books"

# ─────────────────────────────────────────────
# Auth.js (next-auth)
# Generate with: openssl rand -base64 32
# ─────────────────────────────────────────────
AUTH_SECRET="your-super-secret-key-change-in-production"
# AUTH_URL and NEXTAUTH_URL are not needed — trustHost: true resolves from the incoming request
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="XAI Books"

# ─────────────────────────────────────────────
# Email (SMTP)
# Development: use Mailhog (smtp://localhost:1025)
# Production: use your SMTP provider
# ─────────────────────────────────────────────
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="XAI Books <noreply@xaibooks.ae>"

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
RATE_LIMIT_MAX_ATTEMPTS="5"
RATE_LIMIT_WINDOW_MINUTES="15"
