# ─────────────────────────────────────────────
# DEV flow: `npm run dev` on your laptop, Postgres on a remote server over Tailscale.
# Copy to web/.env, then point WEB_DATABASE_URL at the tailnet host (MagicDNS name or
# 100.x tailnet IP). Start the DB on the remote box with:
#   docker compose -f docker-compose.dev.yml up -d
# ─────────────────────────────────────────────

# WEB_DATABASE_URL is what Prisma reads. Replace <tailnet-host> and <password>.
WEB_DATABASE_URL="postgresql://xai_books:<password>@<tailnet-host>:5432/xai_books"
DATABASE_URL="postgresql://xai_books:<password>@<tailnet-host>:5432/xai_books"

# ─────────────────────────────────────────────
# Auth.js (next-auth) — generate with: openssl rand -base64 32
# ─────────────────────────────────────────────
AUTH_SECRET="change-me"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="XAI Books"

# ─────────────────────────────────────────────
# Email (SMTP) — leave blank locally; mail is logged. Point at a real SMTP if needed.
# ─────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT=""
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="XAI Books <noreply@xaibooks.ae>"

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
RATE_LIMIT_MAX_ATTEMPTS="5"
RATE_LIMIT_WINDOW_MINUTES="15"
