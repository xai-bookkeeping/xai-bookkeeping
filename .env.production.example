# ─────────────────────────────────────────────
# PRODUCTION env template — Neon (Postgres) + Vercel / Render / Railway (web).
#
# Vercel/Render/Railway: paste these vars into the platform's env dashboard.
# Self-host fallback: copy to web/.env and run `docker compose -f docker-compose.prod.yml up --build`.
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# Database (Neon) — WEB_DATABASE_URL is what Prisma reads. Always keep ?sslmode=require.
#
#  - Vercel/Render/Railway (serverless): use the Neon POOLED string (-pooler host) so
#    many short-lived functions don't exhaust connections. Run migrations separately
#    against the DIRECT string: `WEB_DATABASE_URL=<direct> npm run db:migrate:deploy`.
#  - Self-host container (docker-compose.prod.yml): a single long-lived process — just
#    use the DIRECT (unpooled) string for WEB_DATABASE_URL; it serves runtime + migrate.
# ─────────────────────────────────────────────
WEB_DATABASE_URL="postgresql://USER:PASSWORD@EP-xxxx-pooler.REGION.aws.neon.tech/xai_books?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@EP-xxxx-pooler.REGION.aws.neon.tech/xai_books?sslmode=require"
# Direct (unpooled) endpoint — use for migrations / self-host runtime:
# DIRECT: postgresql://USER:PASSWORD@EP-xxxx.REGION.aws.neon.tech/xai_books?sslmode=require

# ─────────────────────────────────────────────
# Clerk
# ─────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/register"
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

# ─────────────────────────────────────────────
# Application — real public domain
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://app.xaibooks.ae"
NEXT_PUBLIC_APP_NAME="XAI Books"

# ─────────────────────────────────────────────
# Email (SMTP) — real provider (Resend / SendGrid / SES)
# ─────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="XAI Books <noreply@xaibooks.ae>"

# ─────────────────────────────────────────────
# Self-host container only (docker-compose.prod.yml sets this already):
# DB_MIGRATE_STRATEGY="deploy"
